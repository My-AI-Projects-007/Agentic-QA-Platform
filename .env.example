# Environment Configuration
# Copy this to .env and fill in with actual values

# Application Environment
ENV=development
DEBUG=True

# Database
DATABASE_URL=sqlite:///./data/qa_platform.db
SQL_ECHO=False

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=gpt-4
TEMPERATURE=0.7

# LangSmith Configuration (Observability)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=agentic-qa-platform
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Application Configuration
TARGET_WEBSITE_URL=https://demo.opencart.com/
MAX_ITERATIONS=10
TIMEOUT_SECONDS=300

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# File Paths
REQUIREMENTS_PATH=./requirements_folder
DATA_PATH=./data
